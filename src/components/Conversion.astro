---
import content from "../content/es.json";
import ConversionMotion from "./motion/ConversionMotion.jsx";
---

<ConversionMotion data={content} client:load />

<style is:global>
  /* =========================================================
     CONVERSION — sección final de conversión
     Fondo oscuro (--color-night-900) para crear un cierre con
     peso y contraste tras toda la web clara.
     Tarjeta crema elevada sobre el oscuro: la zona de conversión.
     Rojo: solo el eyebrow dot (permitido) y errores de formulario.
  ========================================================= */

  .conv-section {
    position: relative;
    overflow: clip;
    padding-block: clamp(5rem, 9vw, 8rem);
    background:
      radial-gradient(ellipse at 25% 0%, rgba(36, 32, 27, 0.55), transparent 55%),
      var(--color-night-900);
    /* Grano de papel adaptado al oscuro — más visible */
    --paper-grain-opacity: 0.07;
  }

  /* =========================================================
     LAYOUT PRINCIPAL — dos columnas editorial
  ========================================================= */

  .conv-inner {
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(0, 1.12fr);
    gap: clamp(3rem, 6vw, 5.5rem);
    align-items: center;
  }

  /* =========================================================
     COLUMNA IZQUIERDA — CTA emocional sobre oscuro
  ========================================================= */

  .conv-cta {
    display: grid;
    gap: clamp(1.5rem, 2.5vw, 2.2rem);
    align-content: center;
  }

  .conv-kicker {
    display: grid;
    width: fit-content;
    gap: var(--space-sm);
  }

  /* El eyebrow rojo sí funciona sobre oscuro — micro-acento permitido */
  .conv-eyebrow {
    color: var(--color-accent-red);
  }

  /* Título Fraunces en crema sobre oscuro */
  .conv-title {
    display: flex;
    flex-direction: column;
    margin: 0;
    color: var(--color-cream-100);
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 5vw, 5rem);
    font-weight: 820;
    letter-spacing: var(--tracking-heading);
    line-height: 0.96;
    font-variation-settings: "opsz" var(--font-display-opsz-lg), "SOFT" 0, "WONK" 1;
  }

  /* Primera línea — peso visual máximo */
  .conv-title-l1 {
    display: block;
  }

  /* Segunda línea — misma escala, crea la pausa */
  .conv-title-l2 {
    display: block;
    /* Ligero desplazamiento para ritmo visual */
    padding-left: clamp(0.25rem, 0.5vw, 0.5rem);
    color: color-mix(in srgb, var(--color-cream-100) 78%, var(--color-stone-300));
  }

  /* Lead sobre oscuro: crema atemperada para contraste AA */
  .conv-lead {
    margin: 0;
    max-width: 38ch;
    color: var(--color-stone-300);
    font-size: clamp(1rem, 1.2vw, 1.15rem);
    line-height: var(--leading-body);
  }

  /* Señal de confianza — icono + texto en fila */
  .conv-trust {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    color: color-mix(in srgb, var(--color-stone-300) 65%, transparent);
    font-size: var(--text-caption);
    line-height: 1.55;
  }

  .conv-trust-icon {
    flex-shrink: 0;
    width: 1.1rem;
    height: 1.1rem;
    margin-top: 0.15em;
  }

  /* =========================================================
     TARJETA DEL FORMULARIO
     Cream-100 elevada sobre el fondo oscuro.
  ========================================================= */

  .conv-card {
    background: var(--color-cream-100);
    border-radius: var(--radius-lg);
    padding: clamp(1.75rem, 3.5vw, 2.75rem);
    /* Sombra adaptada para oscuro: más difusa y con opacidad extra */
    box-shadow:
      0 0 0 1px rgba(247, 244, 239, 0.06),
      0 8px 24px rgba(0, 0, 0, 0.32),
      0 28px 56px rgba(0, 0, 0, 0.28),
      0 56px 96px rgba(0, 0, 0, 0.18);
  }

  /* =========================================================
     FORMULARIO — campos
  ========================================================= */

  .conv-form {
    display: grid;
    gap: clamp(1.1rem, 2vw, 1.4rem);
  }

  /* Wrapper de campo individual */
  .conv-field {
    display: grid;
    gap: 0.4rem;
  }

  /* Etiqueta */
  .conv-label {
    display: block;
    color: var(--color-ink-800);
    font-size: var(--text-caption);
    font-weight: 600;
    letter-spacing: 0.01em;
    line-height: 1.3;
  }

  .conv-required {
    color: var(--color-accent-red);
  }

  /* Input y textarea comparten estilos base */
  .conv-input {
    display: block;
    width: 100%;
    min-height: 2.85rem;
    padding: 0.7rem 0.9rem;
    background: color-mix(in srgb, var(--color-cream-100) 50%, white);
    border: 1px solid color-mix(in srgb, var(--color-ink-900) 16%, transparent);
    border-radius: var(--radius-sm);
    color: var(--color-ink-900);
    font-family: var(--font-sans);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body);
    transition:
      border-color var(--duration-fast) var(--ease-signature),
      box-shadow var(--duration-fast) var(--ease-signature);
    -webkit-appearance: none;
    appearance: none;
  }

  .conv-input::placeholder {
    color: var(--color-stone-500);
  }

  .conv-input:focus {
    outline: none;
    border-color: var(--color-ink-900);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-ink-900) 10%, transparent);
  }

  .conv-input:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  /* Campo con error */
  .conv-field.has-error .conv-input {
    border-color: var(--color-accent-red);
  }

  .conv-field.has-error .conv-input:focus {
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent-red) 14%, transparent);
  }

  /* Textarea */
  .conv-textarea {
    min-height: 7rem;
    resize: vertical;
  }

  /* Mensaje de error inline */
  .conv-field-error {
    color: var(--color-accent-red);
    font-size: var(--text-caption);
    line-height: 1.35;
    margin: 0;
    overflow: hidden;
  }

  /* =========================================================
     CONSENTIMIENTO RGPD
     Texto aislado en es.json > formulario.consent para que
     sea fácil de sustituir al clonar para otro mercado.
  ========================================================= */

  .conv-consent {
    display: grid;
    gap: 0.35rem;
  }

  .conv-consent-label {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    cursor: pointer;
  }

  .conv-consent-check {
    flex-shrink: 0;
    width: 1.1rem;
    height: 1.1rem;
    margin-top: 0.15em;
    accent-color: var(--color-ink-900);
    cursor: pointer;
  }

  .conv-consent-check:focus-visible {
    outline: 2px solid var(--color-accent-red);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .conv-consent-check:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .conv-consent-text {
    color: var(--color-stone-600);
    font-size: var(--text-caption);
    line-height: 1.55;
  }

  /* El enlace de privacidad usa el underline animado de base.css */
  .conv-consent-link {
    color: var(--color-ink-800);
    font-weight: 500;
  }

  .conv-consent.has-error .conv-consent-check {
    outline: 2px solid var(--color-accent-red);
    outline-offset: 1px;
    border-radius: 2px;
  }

  /* =========================================================
     ERROR GLOBAL (fallo de red)
  ========================================================= */

  .conv-global-error {
    padding: 0.7rem 0.9rem;
    background: color-mix(in srgb, var(--color-accent-red) 6%, var(--color-cream-100));
    border: 1px solid color-mix(in srgb, var(--color-accent-red) 22%, transparent);
    border-radius: var(--radius-sm);
    color: var(--color-accent-red-dark);
    font-size: var(--text-caption);
    line-height: 1.45;
    margin: 0;
  }

  /* =========================================================
     BOTÓN Y MICROCOPY
  ========================================================= */

  .conv-submit-wrap {
    display: grid;
    gap: 0.6rem;
    padding-top: clamp(0.25rem, 0.5vw, 0.4rem);
  }

  /* Botón de envío — primario full-width en la tarjeta */
  .conv-submit {
    width: 100%;
    min-height: 3.25rem;
    font-size: 1rem;
    letter-spacing: 0.005em;
    gap: 0.5rem;
  }

  .conv-submit:disabled {
    opacity: 0.75;
    cursor: not-allowed;
    transform: none !important;
  }

  /* Spinner CSS — aparece durante el envío */
  .conv-spinner {
    display: inline-block;
    width: 1.1rem;
    height: 1.1rem;
    border: 2px solid color-mix(in srgb, var(--color-cream-100) 30%, transparent);
    border-top-color: var(--color-cream-100);
    border-radius: var(--radius-pill);
    animation: conv-spin 0.65s linear infinite;
    flex-shrink: 0;
  }

  @keyframes conv-spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* Microcopy bajo el botón */
  .conv-microcopy {
    text-align: center;
    color: var(--color-stone-500);
    font-size: var(--text-caption);
    line-height: 1.4;
    margin: 0;
  }

  /* =========================================================
     ESTADO DE ÉXITO
  ========================================================= */

  .conv-success {
    display: grid;
    gap: clamp(1rem, 2vw, 1.4rem);
    place-items: center;
    text-align: center;
    padding-block: clamp(1.5rem, 3vw, 2.5rem);
  }

  /* Círculo con check animado */
  .conv-check-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .conv-check-circle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, #4e7e60 12%, var(--color-cream-100));
    color: #4e7e60;
    border: 1.5px solid color-mix(in srgb, #4e7e60 22%, transparent);
  }

  .conv-check-svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .conv-success-title {
    margin: 0;
    color: var(--color-ink-900);
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2vw, 1.65rem);
    font-weight: 750;
    line-height: 1.2;
    font-variation-settings: "opsz" var(--font-display-opsz-sm), "SOFT" 0, "WONK" 1;
  }

  .conv-success-body {
    margin: 0;
    max-width: 36ch;
    color: var(--color-stone-600);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body);
  }

  /* =========================================================
     RESPONSIVE — tablet
  ========================================================= */

  @media (max-width: 900px) {
    .conv-inner {
      grid-template-columns: 1fr;
      gap: clamp(2.5rem, 5vw, 3.5rem);
    }

    .conv-cta {
      text-align: center;
      place-items: center;
    }

    .conv-lead {
      max-width: none;
      text-align: center;
    }

    .conv-trust {
      justify-content: center;
    }

    .conv-title {
      text-align: center;
    }

    .conv-title-l2 {
      padding-left: 0;
    }

    /* La tarjeta queda centrada y con ancho razonable */
    .conv-card {
      max-width: 38rem;
      margin-inline: auto;
      width: 100%;
    }
  }

  /* =========================================================
     RESPONSIVE — móvil
  ========================================================= */

  @media (max-width: 640px) {
    .conv-section {
      padding-block: clamp(3.5rem, 10vw, 5rem);
    }

    .conv-title {
      font-size: clamp(2.2rem, 9.5vw, 3.2rem);
    }

    .conv-card {
      border-radius: var(--radius-md);
      padding: 1.5rem;
    }

    .conv-input {
      min-height: 3rem; /* área táctil generosa */
    }

    .conv-submit {
      min-height: 3.25rem;
    }
  }

  /* =========================================================
     REDUCED MOTION
  ========================================================= */

  @media (prefers-reduced-motion: reduce) {
    .conv-input {
      transition: none;
    }

    .conv-spinner {
      animation: none;
      opacity: 0.6;
    }
  }
</style>
