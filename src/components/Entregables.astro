---
import content from "../content/es.json";
import EntregablesMotion from "./motion/EntregablesMotion.jsx";

const { entregables } = content;
---

<EntregablesMotion data={entregables} client:load />

<style is:global>
  /* =========================================================
     ENTREGABLES — sección de lista completa de entregables
     Dos columnas editoriales: mensaje izquierdo + checklist derecho.
     Verde calmado para checks; rojo SOLO en eyebrow/rule-draw.
  ========================================================= */

  .del-section {
    --del-check-color: #4e7e60; /* verde calmado y cálido, nunca rojo */

    position: relative;
    overflow: clip;
    padding-block: clamp(4.5rem, 8vw, 7rem);
    background: var(--color-cream-100);
  }

  /* ---- GRID PRINCIPAL ---- */
  .del-grid {
    display: grid;
    grid-template-columns: minmax(18rem, 0.88fr) minmax(0, 1.12fr);
    gap: clamp(3rem, 7vw, 6.5rem);
    align-items: start;
  }

  /* =========================================================
     COLUMNA IZQUIERDA — mensaje
  ========================================================= */

  .del-message {
    display: grid;
    gap: clamp(1.4rem, 2.5vw, 2rem);
    align-content: start;
  }

  /* Eyebrow + rule-draw */
  .del-kicker {
    display: grid;
    width: fit-content;
    gap: var(--space-sm);
  }

  /* Título editorial — Fraunces h2 con presencia */
  .del-title {
    max-width: 16ch;
    color: var(--color-ink-900);
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4.2vw, 4.2rem);
    font-weight: 820;
    letter-spacing: var(--tracking-heading);
    line-height: 0.98;
    font-variation-settings: "opsz" var(--font-display-opsz-lg), "SOFT" 0, "WONK" 1;
  }

  /* Lead — sans, secundario */
  .del-lead {
    max-width: 34ch;
    color: var(--color-stone-600);
    font-size: var(--text-body);
    line-height: var(--leading-body);
  }

  /* Wrapper del botón para que el MotionReveal no afecte al width */
  .del-cta-wrap {
    padding-top: var(--space-xs);
  }

  /* Botón primario — ancho natural en desktop */
  .del-cta {
    width: fit-content;
  }

  /* =========================================================
     COLUMNA DERECHA — checklist agrupado
  ========================================================= */

  .del-checklist {
    display: grid;
    gap: clamp(2rem, 3.5vw, 3rem);
  }

  /* ---- GRUPO ---- */
  .del-group {
    display: grid;
    gap: clamp(0.85rem, 1.4vw, 1.1rem);
  }

  /* Subtítulo de grupo: pequeño, uppercase, discreto */
  .del-group-label {
    margin: 0;
    color: var(--color-stone-500);
    font-size: var(--text-label);
    font-weight: 700;
    letter-spacing: var(--tracking-label);
    line-height: var(--leading-tight);
    text-transform: uppercase;
  }

  /* Lista de ítems — sin padding/margin por defecto */
  .del-group-items {
    display: grid;
    gap: clamp(0.65rem, 1vw, 0.9rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* ---- ÍTEM INDIVIDUAL ---- */
  .del-item {
    display: flex;
    align-items: center;
    gap: clamp(0.65rem, 1vw, 0.85rem);
  }

  /* Icono de check: fondo verde muy suave + icono verde */
  .del-check {
    display: inline-flex;
    flex-shrink: 0;
    width: 1.45rem;
    height: 1.45rem;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-xs);
    background: color-mix(in srgb, var(--del-check-color) 11%, var(--color-cream-100));
    color: var(--del-check-color);
  }

  /* Etiqueta del ítem */
  .del-label {
    color: var(--color-ink-800);
    font-size: var(--text-body);
    font-weight: 500;
    line-height: var(--leading-tight);
  }

  /* =========================================================
     RESPONSIVE
  ========================================================= */

  /* Tablet — apilado */
  @media (max-width: 860px) {
    .del-grid {
      grid-template-columns: 1fr;
      gap: clamp(2.5rem, 5vw, 4rem);
    }

    .del-title {
      max-width: none;
      font-size: clamp(2.2rem, 8vw, 3.4rem);
    }

    .del-lead {
      max-width: none;
    }
  }

  /* Móvil — botón full-width */
  @media (max-width: 640px) {
    .del-cta {
      width: 100%;
    }

    .del-checklist {
      gap: clamp(1.75rem, 6vw, 2.5rem);
    }
  }

  /* =========================================================
     REDUCED MOTION
     Checks visibles por defecto; sin transiciones.
  ========================================================= */

  @media (prefers-reduced-motion: reduce) {
    .del-item,
    .del-check {
      transition: none;
    }
  }
</style>
