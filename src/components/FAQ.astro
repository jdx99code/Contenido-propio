---
import content from "../content/es.json";
import FaqMotion from "./motion/FaqMotion.jsx";

const { faq } = content;
---

<FaqMotion data={faq} client:load />

<style is:global>
  /* =========================================================
     FAQ — acordeón de preguntas frecuentes
     Semántica: <details>/<summary> como base accesible y SEO.
     Framer Motion anima la altura y el icono encima.

     CAPAS DE ESTILO:
     • Números editoriales 01–08 en Fraunces (columna fija izquierda).
     • Barra de acento roja (2 px) que se dibuja al abrir.
     • Fondo cálido que aparece en el ítem activo.
     Rojo permitido SOLO como micro-detalle: barra + indicador activo.
  ========================================================= */

  /* Variables locales del componente */
  .faq-list {
    --faq-num-w: 2.75rem;
    --faq-col-gap: clamp(0.9rem, 1.5vw, 1.4rem);
  }

  .faq-section {
    position: relative;
    overflow: clip;
    padding-block: clamp(4.5rem, 8vw, 7rem);
    background: var(--color-cream-200);
  }

  /* =========================================================
     CONTENEDOR
  ========================================================= */

  .faq-inner {
    display: grid;
    gap: clamp(2.5rem, 4vw, 3.5rem);
  }

  /* =========================================================
     CABECERA
  ========================================================= */

  .faq-header {
    display: grid;
    gap: clamp(1.1rem, 1.8vw, 1.5rem);
    max-width: 48rem;
  }

  .faq-kicker {
    display: grid;
    width: fit-content;
    gap: var(--space-sm);
  }

  .faq-title {
    color: var(--color-ink-900);
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4.2vw, 4.2rem);
    font-weight: 820;
    letter-spacing: var(--tracking-heading);
    line-height: 0.98;
    font-variation-settings: "opsz" var(--font-display-opsz-lg), "SOFT" 0, "WONK" 1;
    margin: 0;
  }

  /* =========================================================
     LISTA DEL ACORDEÓN
  ========================================================= */

  .faq-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid color-mix(in srgb, var(--color-ink-900) 10%, transparent);
  }

  /* =========================================================
     ÍTEM — fila del acordeón
  ========================================================= */

  .faq-item {
    position: relative;          /* ancla la barra y el fondo */
    border-bottom: 1px solid color-mix(in srgb, var(--color-ink-900) 10%, transparent);
    transition: none;            /* Framer Motion maneja el x hover */
  }

  /* ── Capa de fondo ───────────────────────────────────────
     Un rect absoluto que cubre todo el ítem; aparece con fade
     cuando está abierto. Crea la sensación de "ítem activo"
     sin borders llamativos. */
  .faq-item-bg {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--color-cream-100) 65%, transparent);
    border-radius: var(--radius-xs, 4px);
    pointer-events: none;
    z-index: 0;
  }

  /* ── Barra de acento ─────────────────────────────────────
     2 px roja anclada al borde izquierdo del ítem.
     Framer Motion anima scaleY 0→1 desde arriba + opacity.
     Es el único rojo estructural permitido aquí. */
  .faq-accent-bar {
    position: absolute;
    left: 0;
    top: 0;
    width: 2px;
    height: 100%;
    background: var(--color-accent-red);
    border-radius: 0 1px 1px 0;
    pointer-events: none;
    z-index: 1;
  }

  /* details encima de las capas decorativas */
  .faq-item details {
    position: relative;
    z-index: 2;
  }

  /* =========================================================
     SUMMARY — cabecera clicable de cada ítem
     Grid de 3 columnas: número | pregunta | icono
  ========================================================= */

  .faq-summary {
    display: grid;
    grid-template-columns: var(--faq-num-w) 1fr auto;
    column-gap: var(--faq-col-gap);
    align-items: center;
    padding-block: clamp(1.1rem, 2vw, 1.5rem);
    cursor: pointer;
    list-style: none; /* elimina el triángulo nativo en Firefox */
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }

  /* Elimina el triángulo nativo en Webkit */
  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-summary::marker {
    display: none;
  }

  /* Foco visible accesible */
  .faq-summary:focus-visible {
    outline: 2px solid var(--color-accent-red);
    outline-offset: 4px;
    border-radius: var(--radius-xs);
  }

  /* Hover sutil en toda la fila */
  .faq-item:hover .faq-question-text {
    color: var(--color-ink-900);
  }

  .faq-item:hover .faq-num {
    color: color-mix(in srgb, var(--color-ink-900) 42%, transparent);
  }

  /* =========================================================
     NÚMERO EDITORIAL — columna izquierda
     Fraunces tabular, mudo por defecto.
     Se oscurece/calienta al abrir.
  ========================================================= */

  .faq-num {
    display: block;
    color: color-mix(in srgb, var(--color-ink-900) 22%, transparent);
    font-family: var(--font-display);
    font-size: clamp(0.775rem, 0.9vw, 0.875rem);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.04em;
    line-height: 1;
    font-variation-settings: "opsz" var(--font-display-opsz-sm, 14), "SOFT" 0, "WONK" 0;
    transition: color var(--duration-standard) var(--ease-signature);
    /* Alinea con la primera línea del texto de la pregunta */
    padding-top: 0.2em;
  }

  /* Número más visible cuando el ítem está abierto */
  .faq-item.is-open .faq-num {
    color: color-mix(in srgb, var(--color-ink-900) 60%, transparent);
  }

  /* =========================================================
     TEXTO DE LA PREGUNTA
  ========================================================= */

  .faq-question-text {
    color: var(--color-ink-800);
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.25vw, 1.15rem);
    font-weight: 600;
    line-height: 1.45;
    transition: color var(--duration-standard) var(--ease-signature);
  }

  .faq-item.is-open .faq-question-text {
    color: var(--color-ink-900);
  }

  /* =========================================================
     ICONO +/× — único lugar donde el rojo aparece como acento
  ========================================================= */

  .faq-icon {
    display: inline-flex;
    flex-shrink: 0;
    width: 1.75rem;
    height: 1.75rem;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--color-ink-900) 14%, transparent);
    background: transparent;
    color: var(--color-stone-500);
    font-size: 1.25rem;
    font-weight: 300;
    line-height: 1;
    /* La rotación la controla Framer Motion; el color cambia con CSS */
    transition:
      color var(--duration-standard) var(--ease-signature),
      border-color var(--duration-standard) var(--ease-signature),
      background-color var(--duration-standard) var(--ease-signature);
  }

  /* Acento rojo SOLO en el icono cuando está abierto — micro-detalle */
  .faq-item.is-open .faq-icon {
    color: var(--color-accent-red);
    border-color: color-mix(in srgb, var(--color-accent-red) 28%, transparent);
    background: color-mix(in srgb, var(--color-accent-red) 5%, var(--color-cream-200));
  }

  /* =========================================================
     CUERPO — contenido de la respuesta (altura animada)
     Indentado para alinearse con el texto de la pregunta.
  ========================================================= */

  .faq-body {
    /* Sin overflow: hidden aquí — Framer Motion lo añade inline tras montar */
  }

  .faq-answer-text {
    max-width: 64ch;
    padding-bottom: clamp(1.1rem, 2vw, 1.5rem);
    /* Indenta con el texto de la pregunta: num + gap */
    padding-left: calc(var(--faq-num-w) + var(--faq-col-gap));
    color: var(--color-stone-600);
    font-size: var(--text-body);
    line-height: var(--leading-body);
    margin: 0;
  }

  /* =========================================================
     RESPONSIVE
  ========================================================= */

  @media (max-width: 640px) {
    .faq-list {
      --faq-num-w: 2.25rem;
      --faq-col-gap: 0.75rem;
    }

    .faq-title {
      font-size: clamp(2rem, 9vw, 3rem);
    }

    .faq-summary {
      padding-block: clamp(1rem, 4vw, 1.25rem);
    }

    /* Área táctil generosa en móvil */
    .faq-icon {
      width: 2rem;
      height: 2rem;
    }
  }

  /* En pantallas muy pequeñas ocultamos el número para ganar espacio */
  @media (max-width: 380px) {
    .faq-list {
      --faq-num-w: 0px;
    }

    .faq-num {
      display: none;
    }

    .faq-summary {
      grid-template-columns: 1fr auto;
    }

    .faq-answer-text {
      padding-left: 0;
    }
  }

  /* =========================================================
     REDUCED MOTION
  ========================================================= */

  @media (prefers-reduced-motion: reduce) {
    .faq-icon,
    .faq-question-text,
    .faq-num {
      transition: none;
    }
  }
</style>
