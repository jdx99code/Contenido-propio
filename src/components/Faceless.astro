---
import content from "../content/es.json";
import FacelessMotion from "./motion/FacelessMotion.jsx";

const { faceless } = content;
---

<FacelessMotion faceless={faceless} client:load />

<style is:global>
  .faceless-section {
    position: relative;
    overflow: clip;
    padding-block: clamp(4.75rem, 8vw, 7.25rem);
    background:
      radial-gradient(circle at 82% 18%, rgba(230, 33, 23, 0.045), transparent 30%),
      linear-gradient(180deg, rgba(238, 232, 221, 0.46), rgba(247, 244, 239, 0)),
      var(--color-cream-100);
  }

  .faceless-inner {
    display: grid;
    gap: clamp(2rem, 4vw, 3.25rem);
  }

  .faceless-header {
    display: grid;
    max-width: 58rem;
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  .faceless-kicker {
    display: grid;
    width: fit-content;
    gap: var(--space-sm);
  }

  .faceless-rule {
    max-width: 5.25rem;
    animation: none;
    transform: scaleX(1);
  }

  .faceless-title {
    color: var(--color-ink-900);
    font-family: var(--font-display);
    font-size: clamp(2.45rem, 4.8vw, 4.65rem);
    font-weight: 820;
    letter-spacing: var(--tracking-heading);
    line-height: 0.98;
    font-variation-settings: "opsz" var(--font-display-opsz-lg), "SOFT" 0, "WONK" 1;
  }

  .faceless-lead {
    max-width: 45rem;
    color: var(--color-stone-600);
    font-size: var(--text-body);
    line-height: var(--leading-body);
  }

  .faceless-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 1.35rem);
  }

  .faceless-card {
    position: relative;
    display: grid;
    min-height: clamp(17rem, 22vw, 20rem);
    align-content: end;
    gap: var(--space-md);
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-ink-900) 11%, transparent);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.24), rgba(255, 255, 255, 0)),
      color-mix(in srgb, var(--color-cream-100) 88%, var(--color-cream-200));
    padding: clamp(1.35rem, 2.4vw, 2rem);
    box-shadow: var(--elevation-raised);
    transition:
      border-color var(--duration-standard) var(--ease-signature),
      box-shadow var(--duration-standard) var(--ease-signature);
    will-change: transform;
  }

  .faceless-card::before {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: var(--color-accent-red);
    content: "";
    opacity: 0.7;
    transform: scaleX(0.28);
    transform-origin: left center;
    transition:
      opacity var(--duration-standard) var(--ease-signature),
      transform var(--duration-standard) var(--ease-signature);
  }

  .faceless-card:hover {
    border-color: color-mix(in srgb, var(--color-accent-red) 18%, transparent);
    box-shadow: var(--elevation-floating);
  }

  .faceless-card:hover::before {
    opacity: 1;
    transform: scaleX(1);
  }

  .faceless-card-kicker {
    color: var(--color-accent-red);
    font-size: var(--text-label);
    font-weight: 800;
    letter-spacing: var(--tracking-label);
    line-height: var(--leading-tight);
  }

  .faceless-card h3 {
    max-width: 13ch;
    color: var(--color-ink-900);
    font-family: var(--font-display);
    font-size: clamp(1.65rem, 2.4vw, 2.35rem);
    font-weight: 760;
    letter-spacing: var(--tracking-heading);
    line-height: 1.04;
    font-variation-settings: "opsz" var(--font-display-opsz-sm), "SOFT" 0, "WONK" 1;
  }

  .faceless-card p {
    max-width: 38ch;
    color: var(--color-stone-600);
    font-size: var(--text-body-sm);
    line-height: 1.65;
  }

  @media (max-width: 760px) {
    .faceless-grid {
      grid-template-columns: 1fr;
    }

    .faceless-card {
      min-height: 14rem;
    }
  }
</style>
