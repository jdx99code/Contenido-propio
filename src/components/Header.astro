---
import content from "../content/es.json";

const { id = "header" } = Astro.props;
const { site, header, navigation } = content;
---

<header class="site-header" data-section={id}>
  <div class="container header-inner">
    <a class="header-brand" href="/" aria-label={site.name}>
      <span class="brand-mark" aria-hidden="true"></span>
      <span>{header.logoLabel || site.name}</span>
    </a>

    {navigation.items.length > 0 && (
      <nav class="header-nav" aria-label={navigation.label || "Navegación principal"}>
        {navigation.items.map((item) => (
          <a class="header-nav-link" href={item.href}>{item.label}</a>
        ))}
      </nav>
    )}

    {header.cta.label && (
      <a class="button button-primary header-cta" href={header.cta.href}>
        {header.cta.label}
      </a>
    )}
  </div>
</header>

<script>
  const header = document.querySelector(".site-header");

  if (header) {
    const setHeaderState = () => {
      header.classList.toggle("is-scrolled", window.scrollY > 8);
    };

    setHeaderState();
    window.addEventListener("scroll", setHeaderState, { passive: true });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid color-mix(in srgb, var(--color-ink-900) 8%, transparent);
    background: color-mix(in srgb, var(--color-cream-100) 92%, transparent);
    backdrop-filter: blur(18px);
    box-shadow: 0 0 0 rgba(26, 23, 20, 0);
    transition:
      background-color var(--duration-standard) var(--ease-signature),
      border-color var(--duration-standard) var(--ease-signature),
      box-shadow var(--duration-standard) var(--ease-signature);
  }

  .site-header.is-scrolled {
    border-color: color-mix(in srgb, var(--color-ink-900) 12%, transparent);
    background: color-mix(in srgb, var(--color-cream-100) 96%, transparent);
    box-shadow: 0 0.45rem 1.25rem rgba(26, 23, 20, 0.055);
  }

  .header-inner {
    display: flex;
    min-height: 4.5rem;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
  }

  .header-brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-ink-900);
    font-size: var(--text-body-sm);
    font-weight: 800;
    line-height: 1;
    text-decoration: none;
  }

  .brand-mark {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: var(--radius-pill);
    background: var(--color-accent-red);
  }

  .header-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1rem, 2.2vw, 1.8rem);
    margin-inline: auto;
  }

  .header-nav-link {
    color: var(--color-stone-600);
    font-size: 0.92rem;
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
  }

  .header-nav-link:hover {
    color: var(--color-ink-900);
  }

  .header-cta {
    min-height: 2.55rem;
    padding-inline: 1rem;
  }

  @media (max-width: 820px) {
    .header-nav {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .header-inner {
      min-height: 4rem;
    }

    .header-cta {
      width: auto;
    }
  }
</style>
