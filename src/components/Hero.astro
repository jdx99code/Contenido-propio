---
import content from "../content/es.json";
import HeroMotion from "./motion/HeroMotion.jsx";

const { hero } = content;
---

<HeroMotion hero={hero} />

<style is:global>
  .hero-section {
    --success: #2f7d52;
    --success-soft: #dcefe4;
    position: relative;
    overflow: clip;
    padding-block: clamp(5rem, 9vw, 8rem) var(--section-padding-y);
  }

  .hero-section::before {
    position: absolute;
    inset: -20% -10% auto auto;
    width: min(42rem, 70vw);
    height: min(42rem, 70vw);
    border-radius: 999px;
    background: radial-gradient(circle, rgba(238, 232, 221, 0.92), rgba(247, 244, 239, 0));
    content: "";
    pointer-events: none;
  }

  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(21rem, 0.98fr);
    gap: clamp(3rem, 7vw, 6rem);
    align-items: center;
  }

  .hero-copy {
    display: grid;
    gap: var(--space-xl);
    max-width: 42rem;
  }

  .hero-kicker {
    display: grid;
    width: fit-content;
    gap: var(--space-sm);
  }

  .hero-eyebrow {
    width: fit-content;
  }

  .hero-motion-rule {
    max-width: 5.25rem;
    animation: none;
  }

  .hero-title {
    display: grid;
    gap: var(--space-sm);
    color: var(--color-ink-900);
    font-family: var(--font-display);
    font-size: clamp(4rem, 8.4vw, 7.8rem);
    font-weight: 850;
    line-height: 0.94;
    letter-spacing: var(--tracking-display);
    font-variation-settings: "opsz" var(--font-display-opsz-xl), "SOFT" 0, "WONK" 1;
  }

  .hero-title-line {
    display: block;
    overflow: hidden;
  }

  .hero-title-line > span {
    display: block;
  }

  .hero-title-warm {
    color: var(--ink-warm);
    font-weight: 720;
  }

  .hero-lead {
    max-width: 39rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .social-proof {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    color: var(--color-stone-600);
    font-size: var(--text-body-sm);
    font-weight: 650;
    line-height: var(--leading-tight);
  }

  .avatar-stack {
    display: flex;
    padding-left: calc(var(--space-sm) * 3);
  }

  .avatar {
    display: inline-grid;
    width: 2.35rem;
    height: 2.35rem;
    margin-left: calc(var(--space-sm) * -1);
    place-items: center;
    border: 2px solid var(--color-cream-100);
    border-radius: var(--radius-pill);
    background:
      linear-gradient(135deg, rgba(247, 244, 239, 0.96), rgba(228, 220, 207, 0.98));
    color: var(--color-ink-800);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    box-shadow: 0 0.35rem 1rem rgba(26, 23, 20, 0.08);
  }

  .avatar:nth-child(even) {
    background: var(--color-ink-900);
    color: var(--color-cream-100);
  }

  .hero-visual {
    position: relative;
    justify-self: end;
    width: min(100%, 35rem);
    padding: clamp(1.75rem, 4vw, 2.8rem);
  }

  .channel-card {
    position: relative;
    isolation: isolate;
    z-index: 1;
    display: grid;
    gap: var(--space-xl);
    padding: clamp(1.35rem, 3vw, 2rem);
    box-shadow:
      0 0 0 1px rgba(247, 213, 142, 0.24),
      0 0 2.4rem rgba(247, 213, 142, 0.22),
      var(--elevation-floating);
    will-change: transform;
  }

  .channel-card::before,
  .channel-card::after {
    position: absolute;
    border-radius: inherit;
    content: "";
    pointer-events: none;
  }

  .channel-card::before {
    z-index: -1;
    inset: -1.15rem;
    background:
      radial-gradient(circle at 25% 12%, rgba(255, 235, 188, 0.36), transparent 38%),
      radial-gradient(circle at 78% 82%, rgba(247, 213, 142, 0.26), transparent 42%);
    filter: blur(1.15rem);
    opacity: 0.72;
    animation: channel-led-breathe 5.6s var(--ease-signature) infinite;
  }

  .channel-card::after {
    inset: -1px;
    border: 1px solid rgba(247, 213, 142, 0.42);
    box-shadow:
      inset 0 0 0.75rem rgba(255, 236, 198, 0.2),
      0 0 1.35rem rgba(247, 213, 142, 0.24);
    opacity: 0.84;
  }

  .channel-header,
  .channel-identity {
    display: flex;
    align-items: center;
  }

  .channel-header {
    justify-content: space-between;
    gap: var(--space-lg);
  }

  .channel-identity {
    min-width: 0;
    gap: var(--space-md);
  }

  .play-icon {
    display: inline-grid;
    flex: 0 0 auto;
    width: 2.85rem;
    height: 2.85rem;
    place-items: center;
    border-radius: 0.85rem;
    background: var(--color-accent-red);
    color: white;
    box-shadow: 0 0.7rem 1.4rem rgba(230, 33, 23, 0.18);
  }

  .play-icon svg {
    width: 1.55rem;
    height: 1.55rem;
    fill: currentColor;
  }

  .channel-identity h2 {
    color: var(--color-ink-900);
    font-size: var(--text-body);
    font-weight: 850;
    line-height: var(--leading-tight);
  }

  .channel-identity p,
  .video-copy p {
    color: var(--color-stone-600);
    font-size: var(--text-caption);
    line-height: 1.45;
  }

  .status-pill {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border-radius: var(--radius-pill);
    background: var(--success-soft);
    color: var(--success);
    padding: 0.42rem 0.65rem;
    font-size: 0.72rem;
    font-weight: 800;
    line-height: 1;
  }

  .status-pill::before {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: var(--radius-pill);
    background: currentColor;
    content: "";
  }

  .status-pill::after {
    position: absolute;
    left: 0.65rem;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: var(--radius-pill);
    background: currentColor;
    content: "";
    opacity: 0.28;
    animation: status-pulse 2.8s var(--ease-signature) infinite;
  }

  .video-list {
    display: grid;
    gap: var(--space-md);
  }

  .video-item {
    display: grid;
    grid-template-columns: 5.8rem minmax(0, 1fr) auto;
    gap: var(--space-md);
    align-items: center;
    border: 1px solid color-mix(in srgb, var(--color-ink-900) 8%, transparent);
    border-radius: var(--radius-md);
    padding: var(--space-sm);
    background: color-mix(in srgb, var(--color-cream-100) 74%, white);
  }

  .video-thumb {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    border-radius: var(--radius-sm);
    background:
      linear-gradient(135deg, rgba(26, 23, 20, 0.06), rgba(26, 23, 20, 0)),
      var(--color-cream-200);
  }

  .video-thumb span {
    position: absolute;
    inset: auto 0.55rem 0.55rem auto;
    width: 1.35rem;
    height: 0.25rem;
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--color-accent-red) 42%, var(--color-cream-100));
  }

  .video-copy {
    min-width: 0;
  }

  .video-copy h3 {
    color: var(--color-ink-900);
    font-size: var(--text-body-sm);
    font-weight: 800;
    line-height: 1.25;
  }

  .check-icon {
    display: inline-grid;
    width: 1.75rem;
    height: 1.75rem;
    place-items: center;
    border-radius: var(--radius-pill);
    background: var(--success-soft);
    color: var(--success);
  }

  .check-icon svg {
    width: 1rem;
    height: 1rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.5;
  }

  .dashboard-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-sm);
    border-top: var(--border-subtle);
    padding-top: var(--space-lg);
  }

  .dashboard-stats div {
    display: grid;
    align-content: center;
    min-height: 4rem;
    border-radius: var(--radius-sm);
    background: var(--color-cream-200);
    padding: var(--space-sm);
  }

  .dashboard-stats strong {
    color: var(--color-ink-900);
    font-size: clamp(0.9rem, 1.2vw, 1.05rem);
    font-weight: 850;
    line-height: 1.18;
  }

  .floating-badge {
    position: absolute;
    z-index: 2;
    display: inline-flex;
    max-width: 15.5rem;
    align-items: center;
    gap: var(--space-sm);
    border: 1px solid color-mix(in srgb, var(--color-ink-900) 10%, transparent);
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--color-cream-100) 92%, white);
    box-shadow: var(--elevation-overlay);
    color: var(--color-ink-800);
    padding: 0.72rem 0.9rem;
    font-size: var(--text-caption);
    font-weight: 800;
    line-height: 1.25;
    will-change: transform;
  }

  .badge-growth {
    top: 0.55rem;
    right: -0.45rem;
  }

  .badge-time {
    bottom: 0.6rem;
    left: -0.35rem;
  }

  .badge-icon {
    display: inline-grid;
    flex: 0 0 auto;
    width: 1.7rem;
    height: 1.7rem;
    place-items: center;
    border-radius: var(--radius-pill);
    background: var(--color-cream-200);
    color: var(--color-ink-900);
  }

  .badge-icon svg {
    width: 1rem;
    height: 1rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  @keyframes status-pulse {
    0%,
    100% {
      opacity: 0.24;
      transform: scale(1);
    }

    50% {
      opacity: 0;
      transform: scale(3.3);
    }
  }

  @keyframes channel-led-breathe {
    0%,
    100% {
      opacity: 0.58;
      transform: scale(0.985);
    }

    50% {
      opacity: 0.88;
      transform: scale(1.015);
    }
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-3xl);
    }

    .hero-copy,
    .hero-visual {
      max-width: none;
    }

    .hero-visual {
      justify-self: stretch;
      width: 100%;
      padding-inline: clamp(0.75rem, 4vw, 1.5rem);
    }
  }

  @media (max-width: 640px) {
    .hero-section {
      padding-block-start: var(--space-3xl);
    }

    .hero-title {
      font-size: clamp(3.35rem, 17vw, 4.8rem);
    }

    .hero-actions {
      display: grid;
    }

    .social-proof {
      align-items: flex-start;
    }

    .channel-header {
      align-items: flex-start;
    }

    .video-item {
      grid-template-columns: 4.8rem minmax(0, 1fr);
    }

    .check-icon {
      grid-column: 2;
      justify-self: start;
    }

    .dashboard-stats {
      grid-template-columns: 1fr;
    }

    .floating-badge {
      max-width: min(16rem, calc(100vw - 2rem));
      border-radius: var(--radius-md);
      font-size: 0.8rem;
    }

    .badge-growth {
      top: 0;
      right: 0.25rem;
    }

    .badge-time {
      bottom: 0;
      left: 0.25rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .status-pill::after,
    .channel-card::before {
      animation: none;
    }
  }
</style>
