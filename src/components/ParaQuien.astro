---
import content from "../content/es.json";
import ParaQuienMotion from "./motion/ParaQuienMotion.jsx";

const { paraQuien } = content;
---

<ParaQuienMotion data={paraQuien} />

<style is:global>
  /* =========================================================
     PARA QUIÉN — sección de filtrado y reconocimiento
     Cabecera centrada, fit items en grid 2 columnas (desktop),
     notFit block secundario debajo. Verde para checks; X atenuada
     para descalificación. Rojo SOLO en eyebrow/rule-draw.
  ========================================================= */

  .pq-section {
    --pq-check-color: #4e7e60;        /* verde calmado y cálido */
    --pq-x-color: var(--color-stone-400, #b8b0a4); /* gris atenuado para la X */

    position: relative;
    overflow: clip;
    padding-block: clamp(4.5rem, 8vw, 7rem);
    background:
      radial-gradient(circle at 60% 0%, rgba(122, 106, 90, 0.035), transparent 38%),
      var(--color-cream-100);
  }

  /* =========================================================
     CONTENEDOR PRINCIPAL
  ========================================================= */

  .pq-inner {
    display: grid;
    gap: clamp(2.5rem, 4.5vw, 4rem);
  }

  /* =========================================================
     CABECERA
  ========================================================= */

  .pq-header {
    display: grid;
    gap: clamp(1.25rem, 2vw, 1.75rem);
    max-width: 52rem;
  }

  .pq-kicker {
    display: grid;
    width: fit-content;
    gap: var(--space-sm);
  }

  .pq-title {
    color: var(--color-ink-900);
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4.2vw, 4.2rem);
    font-weight: 820;
    letter-spacing: var(--tracking-heading);
    line-height: 0.98;
    font-variation-settings: "opsz" var(--font-display-opsz-lg), "SOFT" 0, "WONK" 1;
    margin: 0;
  }

  .pq-lead {
    max-width: 46ch;
    color: var(--color-stone-600);
    font-size: var(--text-body);
    line-height: var(--leading-body);
    margin: 0;
  }

  /* =========================================================
     BLOQUE ES PARA TI — 6 ítems protagonistas
  ========================================================= */

  .pq-fit-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(0.65rem, 1.2vw, 0.9rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Tarjeta de ítem fit */
  .pq-fit-item {
    display: flex;
    align-items: flex-start;
    gap: clamp(0.75rem, 1.2vw, 1rem);
    padding: clamp(1rem, 1.8vw, 1.35rem) clamp(1rem, 1.8vw, 1.4rem);
    border: 1px solid color-mix(in srgb, var(--color-ink-900) 9%, transparent);
    border-radius: var(--radius-md);
    background: linear-gradient(
      160deg,
      rgba(255, 255, 255, 0.18) 0%,
      rgba(255, 255, 255, 0) 100%
    );
    cursor: default;
    transition:
      border-color var(--duration-standard) var(--ease-signature),
      box-shadow var(--duration-standard) var(--ease-signature);
    will-change: transform;
  }

  .pq-fit-item:hover {
    border-color: color-mix(in srgb, var(--pq-check-color) 22%, transparent);
    box-shadow: var(--elevation-floating);
  }

  /* Icono check */
  .pq-check {
    display: inline-flex;
    flex-shrink: 0;
    width: 1.45rem;
    height: 1.45rem;
    margin-top: 0.1rem; /* alinea visualmente con la primera línea */
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-xs);
    background: color-mix(in srgb, var(--pq-check-color) 11%, var(--color-cream-100));
    color: var(--pq-check-color);
  }

  .pq-fit-text {
    color: var(--color-ink-800);
    font-size: var(--text-body);
    font-weight: 450;
    line-height: 1.6;
  }

  /* =========================================================
     BLOQUE NO ES PARA TI — secundario, sin protagonismo
  ========================================================= */

  .pq-notfit-block {
    display: grid;
    gap: clamp(1rem, 1.8vw, 1.4rem);
    padding-top: clamp(0.5rem, 1vw, 0.75rem);
    border-top: 1px solid color-mix(in srgb, var(--color-ink-900) 10%, transparent);
  }

  /* Título del bloque negativo — pequeño, uppercase, atenuado */
  .pq-notfit-title {
    color: var(--color-stone-500);
    font-size: var(--text-label);
    font-weight: 700;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    margin: 0;
  }

  .pq-notfit-list {
    display: grid;
    gap: clamp(0.55rem, 0.9vw, 0.75rem);
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 48rem;
  }

  /* Ítem notFit — sin elevación, visualmente secundario */
  .pq-notfit-item {
    display: flex;
    align-items: center;
    gap: clamp(0.6rem, 1vw, 0.8rem);
  }

  /* Icono X atenuado */
  .pq-x-icon {
    display: inline-flex;
    flex-shrink: 0;
    width: 1.3rem;
    height: 1.3rem;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-xs);
    background: color-mix(in srgb, var(--color-ink-900) 6%, var(--color-cream-100));
    color: var(--pq-x-color);
  }

  .pq-notfit-text {
    color: var(--color-stone-600);
    font-size: var(--text-body-sm);
    line-height: 1.55;
  }

  /* Texto de cierre — pequeño, sobrio */
  .pq-closing {
    max-width: 52ch;
    color: var(--color-stone-500);
    font-size: var(--text-caption);
    line-height: 1.65;
    font-style: italic;
    margin: 0;
  }

  /* =========================================================
     RESPONSIVE
  ========================================================= */

  /* Tablet */
  @media (max-width: 860px) {
    .pq-fit-list {
      grid-template-columns: 1fr;
    }

    .pq-title {
      font-size: clamp(2.2rem, 8vw, 3.4rem);
    }
  }

  /* Móvil */
  @media (max-width: 640px) {
    .pq-fit-item {
      padding: 0.9rem 1rem;
    }

    .pq-lead {
      max-width: none;
    }
  }

  /* =========================================================
     REDUCED MOTION
  ========================================================= */

  @media (prefers-reduced-motion: reduce) {
    .pq-fit-item {
      transition: none;
    }
  }
</style>
