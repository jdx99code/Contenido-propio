---
import content from "../content/es.json";
import ProblemaSolucionMotion from "./motion/ProblemaSolucionMotion.jsx";

const { problemaSolucion } = content;
---

<ProblemaSolucionMotion data={problemaSolucion} client:load />

<style is:global>
  .ps-section {
    position: relative;
    overflow: clip;
    padding-block: clamp(4rem, 7vw, 6rem);
    background: var(--color-cream-100);
  }

  .ps-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1.25rem, 3vw, 2rem);
    align-items: stretch;
  }

  .ps-card {
    position: relative;
    display: grid;
    min-height: clamp(21rem, 27vw, 27rem);
    align-content: start;
    gap: clamp(1rem, 2vw, 1.45rem);
    overflow: hidden;
    border-radius: var(--radius-lg);
    padding: clamp(1.65rem, 3vw, 2.35rem);
    will-change: transform;
  }

  .ps-card-problem {
    border: 1px solid color-mix(in srgb, var(--color-ink-900) 10%, transparent);
    background:
      linear-gradient(180deg, rgba(26, 23, 20, 0.025), rgba(26, 23, 20, 0.04)),
      color-mix(in srgb, var(--color-cream-200) 78%, var(--color-stone-200));
    color: var(--color-ink-900);
  }

  .ps-card-solution {
    border: 1px solid color-mix(in srgb, var(--ink-warm) 18%, transparent);
    background:
      radial-gradient(circle at 80% 0%, rgba(247, 244, 239, 0.92), rgba(247, 244, 239, 0) 36%),
      color-mix(in srgb, var(--color-cream-100) 90%, var(--color-cream-200));
    color: var(--color-ink-900);
  }

  .ps-solution-rule {
    position: absolute;
    top: 0;
    left: clamp(1.65rem, 3vw, 2.35rem);
    width: min(7rem, 32%);
    height: 2px;
    background: var(--color-accent-red);
    animation: none;
    transform: scaleX(1);
    transform-origin: left center;
  }

  .ps-eyebrow {
    width: fit-content;
    color: var(--color-stone-600);
    font-size: var(--text-label);
    font-weight: 800;
    letter-spacing: var(--tracking-label);
    line-height: var(--leading-tight);
    text-transform: uppercase;
  }

  .ps-card-solution .ps-eyebrow {
    color: var(--ink-warm);
  }

  .ps-card h2 {
    max-width: 13ch;
    color: var(--color-ink-900);
    font-family: var(--font-display);
    font-size: clamp(2.1rem, 3.9vw, 3.65rem);
    font-weight: 820;
    letter-spacing: var(--tracking-heading);
    line-height: 1;
    font-variation-settings: "opsz" var(--font-display-opsz-lg), "SOFT" 0, "WONK" 1;
  }

  .ps-card-solution h2 {
    color: var(--ink-warm);
  }

  .ps-card > p:last-child {
    max-width: 32rem;
    color: var(--color-ink-700);
    font-size: clamp(1rem, 1.2vw, 1.12rem);
    line-height: 1.62;
  }

  .ps-card-problem > p:last-child {
    color: var(--color-stone-600);
  }

  @media (max-width: 860px) {
    .ps-grid {
      grid-template-columns: 1fr;
    }

    .ps-card {
      min-height: auto;
    }
  }
</style>
