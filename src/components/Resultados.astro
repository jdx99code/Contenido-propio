---
import content from "../content/es.json";
import ResultadosMotion from "./motion/ResultadosMotion.jsx";

const { resultados } = content;
---

<ResultadosMotion resultados={resultados} client:load />

<style is:global>
  .results-section {
    position: relative;
    overflow: clip;
    padding-block: clamp(4.5rem, 8vw, 7rem);
  }

  .results-inner {
    display: grid;
    gap: clamp(1.9rem, 4vw, 3.25rem);
  }

  .results-header {
    display: grid;
    justify-items: center;
    gap: var(--space-md);
    text-align: center;
  }

  .results-eyebrow {
    justify-self: center;
  }

  .results-rule {
    max-width: 5.25rem;
    animation: none;
    transform: scaleX(1);
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-ink-900) 10%, transparent);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.34), rgba(255, 255, 255, 0)),
      color-mix(in srgb, var(--color-cream-100) 88%, var(--color-cream-200));
    box-shadow: var(--elevation-raised);
  }

  .result-card {
    position: relative;
    display: grid;
    min-height: clamp(11.5rem, 18vw, 13.5rem);
    align-content: space-between;
    gap: var(--space-lg);
    border: 0;
    border-right: 1px solid color-mix(in srgb, var(--color-ink-900) 8%, transparent);
    border-radius: 0;
    background: transparent;
    box-shadow: none;
    padding: clamp(1.35rem, 2.2vw, 1.85rem);
    will-change: transform;
  }

  .result-card:last-child {
    border-right: 0;
  }

  .result-card::before {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 0%, rgba(122, 106, 90, 0.12), transparent 34%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.16), transparent);
    content: "";
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-standard) var(--ease-signature);
  }

  .result-card:hover::before {
    opacity: 1;
  }

  .result-number-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .result-number {
    color: var(--color-ink-900);
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 4.15vw, 4.25rem);
    font-weight: 820;
    letter-spacing: var(--tracking-display);
    line-height: 0.94;
    font-variation-settings: "opsz" var(--font-display-opsz-lg), "SOFT" 0, "WONK" 1;
  }

  .result-delta {
    flex: 0 0 auto;
    width: fit-content;
    border: 1px solid color-mix(in srgb, #2f7d52 20%, transparent);
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, #2f7d52 10%, var(--color-cream-100));
    color: #2f7d52;
    margin-top: 0.18rem;
    padding: 0.34rem 0.52rem;
    font-size: var(--text-caption);
    font-weight: 850;
    line-height: 1;
  }

  .result-card p {
    color: var(--color-stone-600);
    font-size: var(--text-body-sm);
    font-weight: 650;
    line-height: 1.45;
  }

  .results-note {
    max-width: 46rem;
    justify-self: center;
    color: var(--color-stone-500);
    font-size: var(--text-caption);
    line-height: 1.55;
    text-align: center;
  }

  .studio-frame {
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-ink-900) 10%, transparent);
    border-radius: var(--radius-lg);
    background: var(--color-cream-100);
  }

  @media (max-width: 980px) {
    .results-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .result-card:nth-child(2n) {
      border-right: 0;
    }

    .result-card:nth-child(-n + 2) {
      border-bottom: 1px solid color-mix(in srgb, var(--color-ink-900) 8%, transparent);
    }
  }

  @media (max-width: 560px) {
    .results-grid {
      grid-template-columns: 1fr;
    }

    .result-card {
      min-height: 10.5rem;
      border-right: 0;
      border-bottom: 1px solid color-mix(in srgb, var(--color-ink-900) 8%, transparent);
    }

    .result-card:last-child {
      border-bottom: 0;
    }

    .result-number {
      font-size: clamp(3rem, 15vw, 4.1rem);
    }
  }
</style>
