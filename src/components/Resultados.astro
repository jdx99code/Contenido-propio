---
import content from "../content/es.json";
import ResultadosMotion from "./motion/ResultadosMotion.jsx";

const { resultados } = content;
---

<ResultadosMotion resultados={resultados} client:load />

<style is:global>
  .results-section {
    position: relative;
    overflow: clip;
    padding-block: clamp(4.5rem, 8vw, 7rem);
  }

  .results-inner {
    display: grid;
    gap: clamp(1.9rem, 4vw, 3.25rem);
  }

  .results-studio-shell {
    display: grid;
  }

  .results-header {
    display: grid;
    justify-items: center;
    gap: var(--space-md);
    text-align: center;
  }

  .results-eyebrow {
    justify-self: center;
  }

  .results-rule {
    max-width: 5.25rem;
    animation: none;
    transform: scaleX(1);
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-ink-900) 10%, transparent);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.34), rgba(255, 255, 255, 0)),
      color-mix(in srgb, var(--color-cream-100) 88%, var(--color-cream-200));
    box-shadow: var(--elevation-raised);
  }

  .result-card {
    position: relative;
    display: grid;
    min-height: clamp(10.75rem, 16vw, 12.5rem);
    align-content: space-between;
    gap: clamp(1.1rem, 1.8vw, 1.55rem);
    border: 0;
    border-right: 1px solid color-mix(in srgb, var(--color-ink-900) 8%, transparent);
    border-radius: 0;
    background: transparent;
    box-shadow: none;
    padding: clamp(1.25rem, 1.9vw, 1.65rem);
    will-change: transform;
  }

  .result-card:last-child {
    border-right: 0;
  }

  .result-card::before {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 0%, rgba(122, 106, 90, 0.12), transparent 34%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.16), transparent);
    content: "";
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-standard) var(--ease-signature);
  }

  .result-card:hover::before {
    opacity: 1;
  }

  .result-number-row {
    display: inline-grid;
    width: fit-content;
    max-width: 100%;
    grid-template-columns: minmax(0, auto) auto;
    gap: clamp(0.45rem, 0.8vw, 0.7rem);
    align-items: center;
    justify-self: start;
  }

  .result-number {
    min-width: 0;
    color: var(--color-ink-900);
    font-family: var(--font-display);
    font-size: clamp(2.55rem, 3.55vw, 3.75rem);
    font-weight: 820;
    letter-spacing: var(--tracking-display);
    line-height: 0.94;
    white-space: nowrap;
    font-variation-settings: "opsz" var(--font-display-opsz-lg), "SOFT" 0, "WONK" 1;
  }

  .result-delta {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    width: max-content;
    border: 1px solid color-mix(in srgb, #2f7d52 22%, transparent);
    border-radius: var(--radius-pill);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.32), rgba(255, 255, 255, 0)),
      color-mix(in srgb, #2f7d52 9%, var(--color-cream-100));
    color: #2f7d52;
    margin-top: 0.18em;
    padding: 0.32rem 0.5rem 0.33rem;
    font-size: clamp(0.68rem, 0.78vw, 0.78rem);
    font-weight: 850;
    line-height: 1;
    white-space: nowrap;
    box-shadow: 0 0.35rem 1rem rgba(47, 125, 82, 0.08);
  }

  .result-card:nth-child(4) .result-delta {
    transform: translateX(0.35rem);
  }

  .result-delta::before {
    width: 0.36rem;
    height: 0.36rem;
    border-radius: var(--radius-pill);
    background: currentColor;
    content: "";
    opacity: 0.72;
  }

  .result-card p {
    color: var(--color-stone-600);
    font-size: var(--text-body-sm);
    font-weight: 650;
    line-height: 1.45;
  }

  .results-note {
    max-width: 46rem;
    justify-self: center;
    color: var(--color-stone-500);
    font-size: var(--text-caption);
    line-height: 1.55;
    text-align: center;
  }

  .studio-frame {
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-ink-900) 10%, transparent);
    border-radius: calc(var(--radius-lg) + 0.1rem);
    background: var(--color-cream-100);
    box-shadow: var(--elevation-floating);
  }

  .studio-image {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    object-position: center top;
  }

  @media (max-width: 980px) {
    .results-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .result-card:nth-child(2n) {
      border-right: 0;
    }

    .result-card:nth-child(-n + 2) {
      border-bottom: 1px solid color-mix(in srgb, var(--color-ink-900) 8%, transparent);
    }

    .result-number {
      font-size: clamp(3rem, 7.8vw, 4.35rem);
    }
  }

  @media (max-width: 560px) {
    .results-grid {
      grid-template-columns: 1fr;
    }

    .result-card {
      min-height: 10.5rem;
      border-right: 0;
      border-bottom: 1px solid color-mix(in srgb, var(--color-ink-900) 8%, transparent);
    }

    .result-card:last-child {
      border-bottom: 0;
    }

    .result-number {
      font-size: clamp(3rem, 13vw, 4.05rem);
    }

    .result-delta {
      font-size: 0.76rem;
    }
  }

  @media (max-width: 380px) {
    .result-number-row {
      grid-template-columns: 1fr;
      gap: var(--space-xs);
    }

    .result-delta {
      margin-top: 0;
    }
  }
</style>
