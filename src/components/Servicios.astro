---
import content from "../content/es.json";
import ServiciosMotion from "./motion/ServiciosMotion.jsx";

const { servicios } = content;
---

<ServiciosMotion servicios={servicios} client:load />

<style is:global>
  .services-section {
    position: relative;
    overflow: clip;
    padding-block: clamp(4.5rem, 8vw, 7rem);
    background:
      radial-gradient(circle at top left, rgba(122, 106, 90, 0.04), transparent 28%),
      var(--color-cream-100);
  }

  .services-inner {
    display: grid;
    gap: clamp(2rem, 4vw, 3rem);
  }

  .services-header {
    display: grid;
    gap: clamp(1.35rem, 2.6vw, 1.9rem);
  }

  .services-kicker {
    display: grid;
    width: fit-content;
    gap: var(--space-sm);
  }

  .services-eyebrow {
    width: fit-content;
  }

  .services-rule {
    max-width: 5.25rem;
    animation: none;
    transform: scaleX(1);
  }

  .services-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: clamp(1rem, 3vw, 2rem);
    align-items: end;
  }

  .services-title {
    max-width: 14ch;
    color: var(--color-ink-900);
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 5.3vw, 5rem);
    font-weight: 820;
    letter-spacing: var(--tracking-heading);
    line-height: 0.98;
    font-variation-settings: "opsz" var(--font-display-opsz-lg), "SOFT" 0, "WONK" 1;
  }

  .services-lead {
    max-width: 24rem;
    color: var(--color-stone-600);
    font-size: var(--text-body);
    line-height: var(--leading-body);
  }

  .services-cta {
    justify-self: end;
    align-self: end;
    white-space: nowrap;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 1.25rem);
  }

  .service-card {
    position: relative;
    display: grid;
    min-height: clamp(14rem, 18vw, 16rem);
    gap: var(--space-md);
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-ink-900) 10%, transparent);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0)),
      color-mix(in srgb, var(--color-cream-100) 90%, var(--color-cream-200));
    padding: clamp(1.25rem, 2.2vw, 1.7rem);
    transition:
      border-color var(--duration-standard) var(--ease-signature),
      box-shadow var(--duration-standard) var(--ease-signature),
      transform var(--duration-standard) var(--ease-signature);
    will-change: transform;
  }

  .service-card::before {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at top right, rgba(230, 33, 23, 0.08), transparent 26%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.16), transparent);
    content: "";
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-standard) var(--ease-signature);
  }

  .service-card:hover::before {
    opacity: 1;
  }

  .service-icon {
    display: inline-grid;
    width: 2.65rem;
    height: 2.65rem;
    place-items: center;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-cream-200) 80%, white);
    color: var(--color-ink-900);
    transition:
      color var(--duration-standard) var(--ease-signature),
      transform var(--duration-standard) var(--ease-signature),
      background-color var(--duration-standard) var(--ease-signature);
  }

  .service-icon svg {
    width: 1.35rem;
    height: 1.35rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.5;
  }

  .service-card:hover .service-icon {
    color: var(--color-accent-red);
    transform: translateY(-1px);
    background: color-mix(in srgb, var(--color-cream-100) 88%, white);
  }

  .service-card h3 {
    color: var(--color-ink-900);
    font-size: clamp(1.08rem, 1.35vw, 1.24rem);
    font-weight: 850;
    line-height: 1.18;
  }

  .service-card p {
    max-width: 34ch;
    color: var(--color-stone-600);
    font-size: var(--text-body-sm);
    line-height: 1.6;
  }

  @media (max-width: 980px) {
    .services-heading {
      grid-template-columns: 1fr;
    }

    .services-cta {
      justify-self: start;
    }

    .services-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .services-grid {
      grid-template-columns: 1fr;
    }

    .services-title {
      font-size: clamp(2.45rem, 11vw, 3.55rem);
    }
  }
</style>
