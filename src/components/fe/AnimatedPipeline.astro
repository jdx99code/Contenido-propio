---
import { Check, CircleDot } from "lucide-react";

interface Step {
  title: string;
  body: string;
}

interface Props {
  steps?: Step[];
}

const { steps = [] } = Astro.props;

// Agrupamos en filas de 3 para una cuadricula 3x2 con lineas conectoras
// horizontales entre tarjetas de la misma fila.
const perRow = 3;
const rows: Step[][] = [];
for (let i = 0; i < steps.length; i += perRow) {
  rows.push(steps.slice(i, i + perRow));
}
---

<div class="rounded-[var(--radius)] border border-border bg-background p-6 shadow-warm-card md:p-8">
  <div class="grid gap-8 md:gap-10">
    {rows.map((row, rowIndex) => (
      <div class="grid gap-6 lg:flex lg:items-stretch lg:justify-center">
        {row.map((step, colIndex) => {
          const index = rowIndex * perRow + colIndex;
          return (
            <div class="contents">
              <article class:list={["relative flex min-h-52 flex-col rounded-xl border p-6 transition-colors duration-300 lg:w-64 lg:shrink-0", index === 0 ? "border-accent/35 bg-accent/5" : "border-border bg-secondary/30"]}>
                <div class="mb-5 flex items-center justify-between gap-3">
                  <span class:list={["grid h-9 w-9 place-items-center rounded-full", index === 0 ? "bg-accent text-white" : "bg-stone-200 text-stone-500"]}>
                    {index === 0 ? <Check className="h-4 w-4" /> : <CircleDot className="h-4 w-4" />}
                  </span>
                  <span class="text-xs font-bold uppercase tracking-[0.18em] text-stone-600">{String(index + 1).padStart(2, "0")}</span>
                </div>
                <h3 class="font-heading text-2xl font-semibold text-stone-950">{step.title}</h3>
                <p class="mt-3 text-sm leading-6 text-stone-600">{step.body}</p>
              </article>
              {colIndex < row.length - 1 && (
                <div class="hidden lg:flex lg:flex-1 lg:items-center lg:px-6" aria-hidden="true">
                  <div class="relative h-px w-full bg-border">
                    <div class:list={["absolute inset-y-0 left-0 bg-accent", index === 0 ? "w-full" : "w-0"]}></div>
                  </div>
                </div>
              )}
            </div>
          );
        })}
      </div>
    ))}
  </div>
</div>
