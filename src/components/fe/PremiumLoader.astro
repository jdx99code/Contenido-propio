---
interface Props {
  active?: boolean;
  label?: string;
  duration?: number;
}

const { active = true, label, duration = 900 } = Astro.props;
---

{active && (
  <div data-premium-loader data-duration={duration} hidden class="fixed inset-0 z-50 grid place-items-center bg-stone-950 text-background">
    <div class="grid min-w-64 gap-5 text-center">
      <img src="/logo.svg" alt="" class="mx-auto h-12 w-12 invert" />
      {label && <p class="text-sm font-semibold tracking-[0.18em] text-stone-300 uppercase">{label}</p>}
      <div class="h-px overflow-hidden rounded-full bg-white/10">
        <div class="premium-loader-line h-full bg-accent"></div>
      </div>
    </div>
  </div>
)}

<script>
  const loader = document.querySelector("[data-premium-loader]");

  // Solo en la primera vista de la sesion: en visitas repetidas el loader
  // cuesta ~1,3s de percepcion sin aportar nada. Tambien se omite con
  // prefers-reduced-motion.
  const alreadySeen = (() => {
    try {
      return sessionStorage.getItem("cp-loader-seen") === "1";
    } catch {
      return false;
    }
  })();

  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (loader) {
    if (alreadySeen || reduceMotion) {
      loader.remove();
    } else {
      try {
        sessionStorage.setItem("cp-loader-seen", "1");
      } catch {
        // sin sessionStorage (modo privado estricto) el loader se muestra igual
      }

      const duration = Number(loader.getAttribute("data-duration") || "900");
      loader.hidden = false;

      window.setTimeout(() => {
        loader.classList.add("premium-loader-exit");
        window.setTimeout(() => loader.remove(), 420);
      }, duration);
    }
  }
</script>
