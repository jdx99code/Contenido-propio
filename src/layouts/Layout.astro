---
import "@fontsource/playfair-display/latin-400.css";
import "@fontsource/playfair-display/latin-600.css";
import "@fontsource/playfair-display/latin-700.css";
import "@fontsource/playfair-display/latin-800.css";
import "@fontsource/playfair-display/latin-900.css";
import "@fontsource/inter/latin-400.css";
import "@fontsource/inter/latin-500.css";
import "@fontsource/inter/latin-600.css";
import "@fontsource/inter/latin-700.css";
import "@fontsource/inter/latin-800.css";
import content from "../content/es.json";
import "../styles/index.css";
import "../styles/base.css";

interface AlternateLanguage {
  lang: string;
  href: string;
}

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  alternates?: AlternateLanguage[];
  noindex?: boolean;
  includeFaqSchema?: boolean;
}

const {
  title = content.site.title || content.site.name,
  description = content.site.description,
  ogImage = content.site.ogImage || "/og-image.jpg",
  canonical,
  alternates = [],
  noindex = false,
  includeFaqSchema = false,
} = Astro.props;

const siteName = content.site.name;
const pageTitle = title;
const canonicalUrl = canonical ? new URL(canonical, Astro.site).toString() : new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const siteUrl = new URL("/", Astro.site).toString();
const logoUrl = new URL(content.site.logo || "/logo-512.png", Astro.site).toString();
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteName,
  url: siteUrl,
  logo: logoUrl,
  description: content.site.description,
  sameAs: content.site.sameAs || [],
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: content.faq.items.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<!doctype html>
<html lang={content.site.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={content.site.ogLocale || "es_ES"} />
    <meta property="og:title" content={pageTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageUrl} />

    {alternates.map(({ lang, href }) => <link rel="alternate" hreflang={lang} href={href} />)}
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <link rel="icon" type="image/svg+xml" href="/tab-logo.svg" />
    <link rel="icon" type="image/png" href="/tab-logo-512.png" sizes="512x512" />
    <link rel="apple-touch-icon" href="/tab-logo-512.png" />

    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    {includeFaqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </head>
  <body>
    <slot />
    <script>
      const setupReveal = () => {
        const revealElements = document.querySelectorAll(".reveal:not(.is-visible)");
        const shouldReduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        if (shouldReduceMotion || !("IntersectionObserver" in window)) {
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) {
                return;
              }

              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          { rootMargin: "0px 0px -10% 0px", threshold: 0.05 }
        );

        revealElements.forEach((element) => observer.observe(element));
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", setupReveal, { once: true });
      } else {
        setupReveal();
      }

      import Lenis from "lenis";

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

      if (!reduceMotion.matches) {
        const lenis = new Lenis({
          lerp: 0.075,
          wheelMultiplier: 0.9,
          touchMultiplier: 1.1,
          smoothWheel: true,
        });

        const raf = (time) => {
          lenis.raf(time);
          requestAnimationFrame(raf);
        };

        requestAnimationFrame(raf);
        reduceMotion.addEventListener("change", (event) => {
          if (event.matches) {
            lenis.destroy();
          }
        });
      }
    </script>
  </body>
</html>
