---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Resultados from "../components/Resultados.astro";
import ProblemaSolucion from "../components/ProblemaSolucion.astro";
import Servicios from "../components/Servicios.astro";
import Especializacion from "../components/Especializacion.astro";
import Proceso from "../components/Proceso.astro";
import Entregables from "../components/Entregables.astro";
import ParaQuien from "../components/ParaQuien.astro";
import FAQ from "../components/FAQ.astro";
import content from "../content/es.json";
---

<Layout title={content.site.name} description={content.site.description || undefined}>
  <Header />
  <main id="main-content">
    <Hero />
    <Resultados />
    <ProblemaSolucion />
    <Servicios />
    <Especializacion />
    <Proceso />
    <Entregables />
    <ParaQuien />
    <FAQ />
  </main>
</Layout>
