---
import Layout from "../layouts/Layout.astro";
import content from "../content/es/styleguide.json";
import AnimatedSection from "../components/fe/AnimatedSection.astro";
import TiltCard from "../components/fe/TiltCard.astro";
import MagneticButton from "../components/fe/MagneticButton.astro";
import ParticleField from "../components/fe/ParticleField.astro";
import AnimatedPipeline from "../components/fe/AnimatedPipeline.astro";
import PremiumHeroVisual from "../components/fe/PremiumHeroVisual.astro";
import FAQAccordion from "../components/fe/FAQAccordion.astro";

const buttonClasses = {
  primary:
    "inline-flex min-h-12 items-center justify-center rounded-[var(--radius)] border border-primary bg-primary px-5 py-3 text-sm font-semibold text-primary-foreground transition duration-200 ease-out hover:-translate-y-0.5 hover:bg-stone-800 hover:shadow-lg",
  secondary:
    "inline-flex min-h-12 items-center justify-center rounded-[var(--radius)] border border-stone-300 bg-transparent px-5 py-3 text-sm font-semibold text-stone-900 transition duration-200 ease-out hover:-translate-y-0.5 hover:border-accent/30 hover:bg-stone-900/5 hover:shadow-lg",
  inverse:
    "inline-flex min-h-12 items-center justify-center rounded-[var(--radius)] border border-background bg-background px-5 py-3 text-sm font-semibold text-stone-900 transition duration-200 ease-out hover:-translate-y-0.5 hover:bg-stone-200 hover:shadow-lg",
};

const typeClasses = {
  display: "font-heading text-6xl font-semibold leading-none text-stone-950 md:text-8xl",
  h1: "font-heading text-5xl font-semibold leading-[0.98] text-stone-950 md:text-7xl",
  h2: "font-heading text-4xl font-semibold leading-tight text-stone-950 md:text-6xl",
  h3: "font-heading text-3xl font-semibold leading-tight text-stone-950 md:text-4xl",
  lead: "font-body text-xl leading-8 text-stone-600",
  body: "font-body text-base leading-7 text-stone-700",
  small: "font-body text-sm leading-6 text-stone-500",
};

const dataToneClasses = {
  success: "text-success",
  brand: "text-accent",
};
---

<Layout title={content.meta.title} description={content.meta.description} noindex>
  <main class="min-h-screen overflow-hidden">
    <section class="container-page section-y grid min-h-[76vh] content-end gap-8">
      <p class="text-xs font-bold uppercase tracking-[0.22em] text-accent">{content.hero.eyebrow}</p>
      <div class="max-w-5xl">
        <h1 class="font-heading text-6xl font-semibold leading-[0.95] text-stone-950 sm:text-7xl lg:text-8xl">
          {content.hero.title}
          <span class="gradient-text block">{content.hero.highlight}</span>
        </h1>
      </div>
      <p class="max-w-2xl text-xl leading-8 text-stone-600">{content.hero.lead}</p>
    </section>

    <section class="border-y border-border/70 bg-secondary/35 py-20" aria-labelledby="palette-title">
      <div class="container-page grid gap-10">
        <div class="grid gap-3">
          <p class="text-xs font-bold uppercase tracking-[0.22em] text-accent">{content.palette.eyebrow}</p>
          <h2 id="palette-title" class="font-heading text-4xl font-semibold text-stone-950 md:text-5xl">
            {content.palette.title}
          </h2>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {content.palette.items.map((item) => (
            <article class="rounded-[var(--radius)] border border-border/80 bg-background p-4">
              <div class="mb-4 h-24 rounded-lg border border-stone-900/10" style={`background: ${item.value}`}></div>
              <h3 class="text-sm font-semibold text-stone-950">{item.label}</h3>
              <p class="mt-1 text-xs text-stone-500">{item.token}</p>
              <p class="mt-1 text-xs font-medium text-stone-700">{item.value}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="container-page section-y grid gap-12" aria-labelledby="type-title">
      <div class="grid gap-3">
        <p class="text-xs font-bold uppercase tracking-[0.22em] text-accent">{content.typography.eyebrow}</p>
        <h2 id="type-title" class="font-heading text-4xl font-semibold text-stone-950 md:text-5xl">
          {content.typography.title}
        </h2>
      </div>

      <div class="grid gap-8">
        {content.typography.items.map((item) => (
          <article class="grid gap-5 border-b border-border pb-8 md:grid-cols-[10rem_1fr]">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-accent">{item.label}</p>
            <p class={typeClasses[item.role]}>{item.sample}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="border-y border-border/70 bg-secondary/35 py-20" aria-labelledby="components-title">
      <div class="container-page grid gap-12 lg:grid-cols-[0.8fr_1.2fr]">
        <div class="grid content-start gap-4">
          <p class="text-xs font-bold uppercase tracking-[0.22em] text-accent">{content.components.eyebrow}</p>
          <h2 id="components-title" class="font-heading text-4xl font-semibold text-stone-950 md:text-5xl">
            {content.components.title}
          </h2>
          <p class="text-base leading-7 text-stone-600">{content.components.lead}</p>
        </div>

        <div class="grid gap-6">
          <div class="grid gap-4">
            {content.buttons.items.map((item) => (
              <article class:list={["rounded-[var(--radius)] border p-5", item.variant === "inverse" ? "border-stone-700 bg-stone-950 text-background" : "border-border bg-background"]}>
                <p class:list={["mb-4 text-xs font-bold uppercase tracking-[0.18em]", item.variant === "inverse" ? "text-stone-300" : "text-stone-500"]}>
                  {item.label}
                </p>
                <div class="flex flex-wrap gap-3">
                  <a class={buttonClasses[item.variant]} href="/styleguide">{item.base}</a>
                  <a class:list={[buttonClasses[item.variant], "-translate-y-0.5 shadow-lg", item.variant === "secondary" ? "border-accent/30 bg-stone-900/5" : "", item.variant === "inverse" ? "bg-stone-200" : ""]} href="/styleguide">
                    {item.hover}
                  </a>
                </div>
              </article>
            ))}
          </div>

          <article class="card-hover rounded-[var(--radius)] bg-background p-8">
            <p class="mb-4 text-xs font-bold uppercase tracking-[0.22em] text-accent">{content.card.eyebrow}</p>
            <h3 class="font-heading text-3xl font-semibold text-stone-950">{content.card.title}</h3>
            <p class="mt-4 max-w-xl leading-7 text-stone-600">{content.card.body}</p>
            <div class="mt-8 h-px w-20 bg-accent"></div>
          </article>
        </div>
      </div>
    </section>

    <section class="container-page section-y" aria-labelledby="accent-title">
      <div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-center">
        <div class="grid gap-3">
          <p class="text-xs font-bold uppercase tracking-[0.22em] text-accent">{content.accent.eyebrow}</p>
          <h2 id="accent-title" class="font-heading text-4xl font-semibold text-stone-950 md:text-5xl">
            {content.accent.title}
          </h2>
          <p class="text-base leading-7 text-stone-600">{content.accent.body}</p>
        </div>

        <article class="relative overflow-hidden rounded-[var(--radius)] border border-border bg-background p-8 shadow-warm-card">
          <div class="absolute inset-x-8 top-0 h-px bg-accent/35"></div>
          <div class="absolute -right-24 -top-24 h-64 w-64 rounded-full bg-stone-400/10 blur-3xl"></div>
          <div class="relative grid gap-6">
            <div class="flex items-center gap-3">
              <span class="h-2.5 w-2.5 rounded-full bg-accent"></span>
              <p class="text-sm font-semibold text-stone-900">{content.accent.demo.label}</p>
            </div>
            <div class="grid gap-4 rounded-lg border border-border bg-secondary/40 p-5">
              {content.accent.demo.items.map((item) => (
                <div class="flex items-center justify-between gap-4 border-b border-border/70 pb-3 last:border-0 last:pb-0">
                  <span class="text-sm text-stone-600">{item.label}</span>
                  <strong class:list={["text-base font-bold", dataToneClasses[item.tone] || "text-accent"]}>{item.value}</strong>
                </div>
              ))}
            </div>
            <p class="text-sm leading-6 text-stone-500">{content.accent.demo.note}</p>
          </div>
        </article>
      </div>
    </section>

    <section class="border-y border-border/70 bg-secondary/35 py-20" aria-labelledby="islands-title">
      <div class="container-page grid gap-12">
        <AnimatedSection className="grid max-w-3xl gap-4">
          <p class="text-xs font-bold uppercase tracking-[0.22em] text-accent">{content.islands.eyebrow}</p>
          <h2 id="islands-title" class="font-heading text-4xl font-semibold text-stone-950 md:text-5xl">
            {content.islands.title}
          </h2>
          <p class="text-base leading-7 text-stone-600">{content.islands.lead}</p>
        </AnimatedSection>

        <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
          <TiltCard {...content.islands.tiltCard} />
          <div class="grid content-start gap-6">
            <ParticleField label={content.islands.particleField.label} />
            <div class="rounded-[var(--radius)] border border-border bg-background p-6">
              <MagneticButton href={content.islands.magneticButton.href} label={content.islands.magneticButton.label} />
            </div>
          </div>
        </div>

        <AnimatedPipeline steps={content.islands.pipeline.steps} />

        <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
          <PremiumHeroVisual {...content.islands.heroVisual} />
          <FAQAccordion items={content.islands.faq.items} />
        </div>
      </div>
    </section>
  </main>
</Layout>
